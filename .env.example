# Copy to .env and fill in. All values are optional.

# Free Groq API key from https://console.groq.com/keys
# Without it, the app falls back to a heading-based heuristic (no AI).
GROQ_API_KEY=

# Override the Groq model if you like.
GROQ_MODEL=llama-3.3-70b-versatile

# Max upload size in bytes (default 20 MB).
MAX_UPLOAD_BYTES=20971520
