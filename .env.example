# Copy to .env and fill in. All values are optional.

# Free Groq API key from https://console.groq.com/keys
# Without it, the app falls back to a heading-based heuristic (no AI).
GROQ_API_KEY=

# Override the Groq model if you like.
GROQ_MODEL=llama-3.3-70b-versatile
# Used automatically when the primary model hits its rate/daily limit (separate,
# larger free-tier quota). Set empty to disable fallback.
GROQ_FALLBACK_MODEL=llama-3.1-8b-instant

# Max upload size in bytes (default 20 MB).
MAX_UPLOAD_BYTES=20971520

# Groq token budget. Defaults are tuned for the FREE tier (12k tokens/min,
# 100k tokens/day). Raise these after upgrading to Groq Dev tier for bigger decks.
GROQ_MAX_TOKENS=4000
GROQ_SOURCE_CHARS=9000

# Optional: forward each feedback submission to a webhook (Slack/Discord/Sheets).
FEEDBACK_WEBHOOK_URL=
